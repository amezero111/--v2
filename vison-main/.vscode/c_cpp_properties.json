{
    "configurations": [
        {
            "name": "Engineer",
            "includePath": [
                "${workspaceFolder}/Engineer/Core/Inc",
                "${workspaceFolder}/Engineer/Drivers/STM32F4xx_HAL_Driver/Inc",
                "${workspaceFolder}/Engineer/Drivers/STM32F4xx_HAL_Driver/Inc/Legacy",
                "${workspaceFolder}/Engineer/Drivers/CMSIS/Device/ST/STM32F4xx/Include",
                "${workspaceFolder}/Engineer/Drivers/CMSIS/Include",
                "${workspaceFolder}/Engineer/MODULE/**",
                "${workspaceFolder}/Engineer/BSP/**",
                "${workspaceFolder}/Engineer/APPLICATION/**",
                "${workspaceFolder}/Engineer/Middlewares/Third_Party/FreeRTOS/Source/include",
                "${workspaceFolder}/Engineer/Middlewares/Third_Party/FreeRTOS/Source/portable/RVDS/ARM_CM4F",
                "${workspaceFolder}/Engineer/Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS",
                "${workspaceFolder}/Engineer/Middlewares/ST/ARM/DSP/Inc",
                "${workspaceFolder}/Engineer/**"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "STM32F407xx",
                "__CC_ARM",
                "__arm__"
            ],
            "compilerPath": "",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "browse": {
                "path": [
                    "${workspaceFolder}/Engineer/**"
                ],
                "limitSymbolsToIncludedHeaders": false
            }
        }
    ],
    "version": 4
}
